{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx",
		"jsxImportSource": "@qwik.dev/core",
		"lib": ["ESNext", "DOM"],
		"types": ["node"]
	}
}
